# Database Config
DB_NAME=jira_db
DB_USER=jira_user
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432

# Jira Config
JIRA_DOMAIN=https://your-jira-domain.com/
JIRA_USER=your_email@domain.com  # For Jira Cloud use full email
JIRA_PASSWORD=your_password  # Legacy - not needed if API_TOKEN set
JIRA_API_TOKEN=your_api_token_here  # Required for Jira Cloud
# 2FA Session Cookie - get from browser after login
# Chrome DevTools (F12) > Application > Cookies > 點擊你的 Jira 網域
# 點擊表格任一列 > Ctrl+A 全選 > Ctrl+C 複製 > 貼到此處
JIRA_COOKIE=
# JQL condition for ETL
JIRA_JQL=project in (YOUR_PROJECT) AND status in (Resolved, Closed)

# AI Config
USE_RTK_LLM=N
OPENAI_API_KEY=sk-your-openai-key-here
RTK_LLM_API_KEY=your-rtk-llm-key-here
DEEPSEEK_LLM_API_KEY=sk-your-deepseek-key-here